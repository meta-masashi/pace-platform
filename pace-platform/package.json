{
  "name": "pace-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --no-error-on-unmatched-pattern",
    "test": "vitest --config tests/vitest.config.ts run",
    "test:unit": "vitest --config tests/vitest.config.ts run tests/unit",
    "test:watch": "vitest --config tests/vitest.config.ts",
    "test:coverage": "vitest --config tests/vitest.config.ts run --coverage",
    "test:e2e": "playwright test --config tests/playwright.config.ts",
    "test:e2e:ui": "playwright test --config tests/playwright.config.ts --ui",
    "test:e2e:headed": "playwright test --config tests/playwright.config.ts --headed",
    "test:security": "vitest --config tests/vitest.config.ts run tests/security",
    "test:integration": "vitest --config tests/vitest.config.ts run tests/integration --passWithNoTests",
    "test:all": "npm run test && npm run test:e2e",
    "import:nodes": "tsx scripts/import-nodes.ts",
    "import:exercises": "tsx scripts/import-exercises.ts",
    "import:sample": "tsx scripts/generate-sample-csv.ts",
    "security:audit": "npm audit --omit=dev",
    "security:sbom": "npx @cyclonedx/cyclonedx-npm --output-file sbom.json --omit dev"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@sentry/nextjs": "^8.0.0",
    "@supabase/ssr": "^0.5.0",
    "@supabase/supabase-js": "^2.45.0",
    "@tanstack/react-query": "^5.60.0",
    "googleapis": "^140.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.0",
    "stripe": "^17.7.0",
    "web-vitals": "^3.5.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@next/eslint-plugin-next": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^1.6.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  }
}
