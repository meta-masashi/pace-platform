# PACE CV Engine — Environment Variables
# Copy to .env for local development

# Service
ENVIRONMENT=development
LOG_LEVEL=INFO

# AWS
AWS_REGION=ap-northeast-1
S3_RAW_BUCKET=pace-raw-videos-dev
S3_MASKED_BUCKET=pace-masked-videos-dev
SQS_JOB_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/123456789/pace-cv-jobs-dev.fifo

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Internal auth (service-to-service)
CV_INTERNAL_TOKEN=generate-a-secure-random-token-here

# Sentry (optional)
SENTRY_DSN=

# CV Engine tuning
POSE_MODEL_COMPLEXITY=1
FACE_BLUR_KERNEL=99
MAX_VIDEO_DURATION_SEC=300
MAX_FILE_SIZE_BYTES=524288000

# Worker
WORKER_CONCURRENCY=1
SQS_VISIBILITY_TIMEOUT=300
SQS_MAX_MESSAGES=1
