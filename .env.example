# ============================================================
# PACE Platform v3.2 — 環境変数テンプレート
# ============================================================
# セットアップ手順:
#   cp .env.example .env.local
#   各値を実際の値で埋める
#
# .env.local は .gitignore で除外済み。
# 本番値は Vercel Environment Variables で管理する。
# ============================================================

# ------------------------------------------------------------
# Supabase（フロントエンド公開値）
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[公開可能な匿名キー]

# ------------------------------------------------------------
# Supabase（サーバーサイド専用 — NEXT_PUBLIC_ にしないこと）
# ------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=[サービスロールキー]
SUPABASE_DB_PASSWORD=[DB パスワード]
SUPABASE_PROJECT_REF=[プロジェクト参照ID]

# ------------------------------------------------------------
# Google Gemini API
# ------------------------------------------------------------
GEMINI_API_KEY=[Gemini API キー]
GEMINI_RATE_LIMIT_PER_MIN=20
GEMINI_MONTHLY_CALL_LIMIT=10000

# ------------------------------------------------------------
# Dify API（プロンプト管理・ワークフロー）
# ------------------------------------------------------------
DIFY_API_KEY=[Dify API キー]
DIFY_API_BASE=https://api.dify.ai

# ------------------------------------------------------------
# Stripe（決済）
# ------------------------------------------------------------
STRIPE_SECRET_KEY=[sk_live_... または sk_test_...]
STRIPE_WEBHOOK_SECRET=[whsec_...]
STRIPE_PUBLISHABLE_KEY=[pk_live_... または pk_test_...]
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=[公開キー]
STRIPE_STARTER_PRICE_ID=[starter プラン Price ID]
STRIPE_PRO_PRICE_ID=[pro プラン Price ID]

# ------------------------------------------------------------
# Google Calendar 連携
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=[Google OAuth クライアント ID]
GOOGLE_CLIENT_SECRET=[Google OAuth クライアント シークレット]
GOOGLE_REDIRECT_URI=https://pace.hachi.co.jp/api/calendar/callback
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.readonly
CALENDAR_ENCRYPTION_KEY=[64文字 hex — openssl rand -hex 32]

# ------------------------------------------------------------
# Slack 通知
# ------------------------------------------------------------
SLACK_WEBHOOK_URL=[Slack Incoming Webhook URL]
HACHI_SLACK_WEBHOOK_URL=[PACE Billing 専用 Slack Webhook URL]

# ------------------------------------------------------------
# アプリケーション設定
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://pace.hachi.co.jp
NEXT_PUBLIC_APP_URL=https://pace.hachi.co.jp
NEXT_PUBLIC_ATHLETE_APP_URL=https://athlete.hachi-riskon.com
NODE_ENV=development

# ------------------------------------------------------------
# Observability
# ------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=[Sentry DSN URL]
SENTRY_DSN=[Sentry DSN URL]
SENTRY_ENVIRONMENT=production
LOG_LEVEL=info

# ------------------------------------------------------------
# AWS (Phase 3 CV パイプライン用)
# ------------------------------------------------------------
# AWS_REGION=ap-northeast-1
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# S3_RAW_BUCKET=pace-platform-raw-videos-production
# S3_MASKED_BUCKET=pace-platform-masked-videos-production
# SQS_JOB_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/...
# CV_ENGINE_URL=https://cv-engine.your-domain.com
# CV_INTERNAL_TOKEN=[openssl rand -hex 32]

# ------------------------------------------------------------
# GitHub Actions 専用シークレット（リポジトリ Settings > Secrets）
# ------------------------------------------------------------
# VERCEL_TOKEN
# VERCEL_ORG_ID
# VERCEL_PROJECT_ID
# SUPABASE_ACCESS_TOKEN
