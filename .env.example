# ============================================================
# PACE Platform — 環境変数テンプレート
# ============================================================
# このファイルはコミット対象（実際の値は含まない）
# 実際の値は .env.local に設定し、.gitignore で除外すること
#
# セットアップ手順:
#   cp .env.example .env.local
#   # 各値を実際の値で埋める
# ============================================================

# ------------------------------------------------------------
# Supabase（フロントエンド公開値）
# Supabase Dashboard > Project Settings > API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[公開可能な匿名キー]

# ------------------------------------------------------------
# Supabase（サーバーサイド専用 - 絶対にフロントエンドで使用禁止）
# ------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=[サービスロールキー - サーバーサイドのみ]
SUPABASE_DB_PASSWORD=[DB パスワード - マイグレーション時のみ使用]
SUPABASE_PROJECT_REF=[プロジェクト参照ID - 例: abcdefghijklmnop]

# ------------------------------------------------------------
# Google Gemini API
# https://aistudio.google.com/app/apikey
# ------------------------------------------------------------
GEMINI_API_KEY=[Gemini API キー]
GEMINI_RATE_LIMIT_PER_MIN=20
GEMINI_MONTHLY_CALL_LIMIT=10000

# ------------------------------------------------------------
# Dify API（プロンプト管理・ワークフロー）
# ------------------------------------------------------------
DIFY_API_KEY=[Dify API キー]
DIFY_API_BASE=https://api.dify.ai
# DIFY_API_KEY_REHAB_PROTOCOL_GENERATOR=[ワークフロー別キー]
# DIFY_API_KEY_INJURY_RISK_ANALYZER=[ワークフロー別キー]
# DIFY_API_KEY_RETURN_TO_PLAY_ADVISOR=[ワークフロー別キー]

# ------------------------------------------------------------
# Stripe（決済）
# https://dashboard.stripe.com/apikeys
# ------------------------------------------------------------
STRIPE_SECRET_KEY=[Stripe シークレットキー - sk_live_... または sk_test_...]
STRIPE_WEBHOOK_SECRET=[Webhook署名シークレット - whsec_...]
STRIPE_PUBLISHABLE_KEY=[公開キー - pk_live_... または pk_test_...]
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=[公開キー]
STRIPE_STARTER_PRICE_ID=[starter プラン Price ID - ¥29,800/月]
STRIPE_PRO_PRICE_ID=[pro プラン Price ID - ¥79,800/月]

# ------------------------------------------------------------
# Slack
# ------------------------------------------------------------
SLACK_WEBHOOK_URL=[Slack Incoming Webhook URL - #alerts]
HACHI_SLACK_WEBHOOK_URL=[PACE Billing 専用 Slack Webhook URL]
SLACK_WEBHOOK_PERFORMANCE=[#performance チャンネル]
SLACK_WEBHOOK_COSTS=[#costs チャンネル]
SLACK_WEBHOOK_BILLING=[#billing チャンネル]

# ------------------------------------------------------------
# アプリケーション設定
# ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://hachi-riskon.com
NODE_ENV=development

# ------------------------------------------------------------
# Observability
# ------------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=[Sentry DSN URL]
SENTRY_DSN=[Sentry DSN URL - サーバーサイド専用]
SENTRY_ENVIRONMENT=production
LOG_LEVEL=info
NEXT_PUBLIC_GA4_MEASUREMENT_ID=[G-XXXXXXXXXX]
GA4_API_SECRET=[GA4 Measurement Protocol API Secret - サーバーサイドのみ]

# ------------------------------------------------------------
# Google Calendar OAuth 2.0（スケジュール連携・負荷予測コンテキスト）
# https://console.cloud.google.com/apis/credentials
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=[Google OAuth クライアントID]
GOOGLE_CLIENT_SECRET=[Google OAuth クライアントシークレット]
GOOGLE_REDIRECT_URI=https://hachi-riskon.com/api/auth/callback/google
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.readonly

# ------------------------------------------------------------
# 外部 AI サービス（オプション）
# ------------------------------------------------------------
BAYES_ENGINE_URL=[ベイズエンジン URL - https://bayes.internal/api]
BAYES_ENGINE_API_KEY=[ベイズエンジン API キー]
CV_ANALYSIS_API_URL=[CV解析サービス URL - https://cv.internal/api]
CV_ANALYSIS_API_KEY=[CV解析サービス API キー]

# ------------------------------------------------------------
# Resend（メール送信 — オプション）
# https://resend.com/api-keys
# 未設定の場合は Supabase Edge Function 経由でメール送信
# ------------------------------------------------------------
RESEND_API_KEY=[Resend API キー]
RESEND_FROM_EMAIL=PACE <noreply@hachi-riskon.com>

# ------------------------------------------------------------
# Web Push（VAPID キー — オプション）
# npx web-push generate-vapid-keys で生成
# ------------------------------------------------------------
VAPID_PUBLIC_KEY=[VAPID 公開鍵]
VAPID_PRIVATE_KEY=[VAPID 秘密鍵]
VAPID_SUBJECT=mailto:noreply@hachi-riskon.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=[VAPID 公開鍵 — フロントエンド用]

# ------------------------------------------------------------
# GitHub Actions 専用シークレット（リポジトリ Settings > Secrets で設定）
# ------------------------------------------------------------
# VERCEL_TOKEN         - Vercel アカウント設定 > Tokens
# VERCEL_ORG_ID        - Vercel プロジェクト設定 > Team ID
# VERCEL_PROJECT_ID    - Vercel プロジェクト設定 > Project ID
# SUPABASE_ACCESS_TOKEN - Supabase Dashboard > Account > Access Tokens
