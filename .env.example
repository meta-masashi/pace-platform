# ============================================================
# PACE Platform v3.0 - 環境変数テンプレート
# ============================================================
# 使い方:
#   cp .env.example .env.local
#   各値を実際の値に書き換える
#
# 重要: .env.local は .gitignore に含まれており、
#       コミット・プッシュ禁止。Vercel の Environment Variables
#       で直接設定すること。
# ============================================================

# ------------------------------------------------------------
# Supabase 設定（必須）
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# サービスロールキー（サーバーサイドのみ。NEXT_PUBLIC_ にしないこと）
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------------------------------------------------------------
# AI / LLM 設定（必須）
# ------------------------------------------------------------
# Google Gemini API キー
GEMINI_API_KEY=AIzaSy...

# LangChain / Dify（Phase 2 以降）
# LANGCHAIN_API_KEY=lc-...
# DIFY_API_KEY=app-...

# ------------------------------------------------------------
# Google Calendar 連携（オプション）
# ------------------------------------------------------------
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=https://your-domain.com/api/auth/google/callback

# ------------------------------------------------------------
# AWS 設定（Phase 3 CV パイプライン用）
# ------------------------------------------------------------
# AWS_REGION=ap-northeast-1
# AWS_S3_BUCKET=pace-medical-production
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SQS_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/...

# ------------------------------------------------------------
# Python CV Engine 設定（Phase 3 のみ）
# ------------------------------------------------------------
# CV_ENGINE_ENDPOINT=https://cv-engine.internal/cv
# CV_ENGINE_API_KEY=...

# ------------------------------------------------------------
# Stripe 課金設定（Phase 2 以降）
# ------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ------------------------------------------------------------
# PACE エンジン設定
# ------------------------------------------------------------
# v3 推論モード: shadow | active | disabled（デフォルト: disabled）
PACE_V3_MODE=shadow

# ------------------------------------------------------------
# セキュリティ設定
# ------------------------------------------------------------
# セッションシークレット（ランダム32バイト以上）
# openssl rand -hex 32 で生成すること
# NEXTAUTH_SECRET=（使用しない場合は省略）

# ------------------------------------------------------------
# アプリケーション設定
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://hachi-riskon.com
NEXT_PUBLIC_ATHLETE_APP_URL=https://athlete.hachi-riskon.com

# Node 環境（Vercel が自動設定）
# NODE_ENV=production

# ─── Phase 3: CV Engine & AWS ────────────────────────────────────────────────
# AWS S3 & SQS (CloudFormation outputs from infra/cloudformation/s3-video-pipeline.yaml)
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_RAW_BUCKET=pace-platform-raw-videos-production
S3_MASKED_BUCKET=pace-platform-masked-videos-production
SQS_JOB_QUEUE_URL=https://sqs.ap-northeast-1.amazonaws.com/123456789/pace-platform-cv-jobs-production.fifo

# CV Engine (pace-cv-engine microservice)
CV_ENGINE_URL=https://cv-engine.your-domain.com
CV_INTERNAL_TOKEN=generate-with-openssl-rand-hex-32

# ECR (GitHub Actions deploy)
ECR_REGISTRY=123456789.dkr.ecr.ap-northeast-1.amazonaws.com
