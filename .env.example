# =============================================================================
# pace-platform 環境変数テンプレート
# このファイルはコミット対象です。実際の値は .env.local に設定してください。
# .env.local は .gitignore により Git 管理対象外です。
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase（公開可能 - フロントエンド・サーバーサイド共用）
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[公開可能な匿名キー - Supabase Dashboard > Settings > API]

# -----------------------------------------------------------------------------
# Supabase（秘密 - サーバーサイドのみ / クライアントコードに含めてはならない）
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=[Service Role Key - Supabase Dashboard > Settings > API]
SUPABASE_PROJECT_REF=[プロジェクト参照ID - URLの https://[ref].supabase.co の [ref] 部分]
SUPABASE_ACCESS_TOKEN=[アクセストークン - Supabase Dashboard > Account > Access Tokens]

# Supabase 接続（サーバーサイドのみ）
SUPABASE_URL=https://[project-ref].supabase.co

# -----------------------------------------------------------------------------
# Google Gemini AI（秘密 - サーバーサイドのみ）
# -----------------------------------------------------------------------------
GEMINI_API_KEY=[Gemini API Key - https://aistudio.google.com/app/apikey]

# コスト保護: モデル設定
GEMINI_MODEL=gemini-1.5-pro
GEMINI_MAX_OUTPUT_TOKENS=2048

# -----------------------------------------------------------------------------
# Dify API（秘密 - サーバーサイドのみ / 将来導入）
# -----------------------------------------------------------------------------
DIFY_API_KEY=[Dify API Key]
DIFY_API_BASE_URL=https://api.dify.ai/v1

# -----------------------------------------------------------------------------
# Stripe 決済（本番環境のみ必須）
# -----------------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=[Stripe 公開可能キー - pk_live_... または pk_test_...]
STRIPE_SECRET_KEY=[Stripe シークレットキー - sk_live_... または sk_test_...]
STRIPE_WEBHOOK_SECRET=[Stripe Webhook シークレット - whsec_...]

# -----------------------------------------------------------------------------
# Vercel（CI/CD 環境変数 - GitHub Actions Secrets に登録）
# -----------------------------------------------------------------------------
VERCEL_TOKEN=[Vercel API Token - https://vercel.com/account/tokens]
VERCEL_ORG_ID=[Vercel Organization ID]
VERCEL_PROJECT_ID=[Vercel Project ID]

# -----------------------------------------------------------------------------
# アプリケーション設定
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# レートリミット設定（秒あたりのリクエスト数）
RATE_LIMIT_AI_PER_MINUTE=10
RATE_LIMIT_API_PER_MINUTE=60
