# =============================================================================
# pace-platform .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# 環境変数（絶対にコミットしてはならない）
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# -----------------------------------------------------------------------------
# Node.js / npm
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------
.next/
out/
build/

# -----------------------------------------------------------------------------
# Supabase ローカル開発
# -----------------------------------------------------------------------------
supabase/.branches
supabase/.temp

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
tsconfig.tsbuildinfo
*.tsbuildinfo

# -----------------------------------------------------------------------------
# テスト / カバレッジ
# -----------------------------------------------------------------------------
coverage/
.nyc_output/

# -----------------------------------------------------------------------------
# OS / エディタ
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# -----------------------------------------------------------------------------
# ログ
# -----------------------------------------------------------------------------
logs/
*.log

# -----------------------------------------------------------------------------
# キャッシュ
# -----------------------------------------------------------------------------
.cache/
.eslintcache
.turbo/
